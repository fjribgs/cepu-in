generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
    Warga
    Admin
}

enum Kategori {
    Listrik
    Bangunan
    Kebersihan
    Keamanan
}

enum Status {
    Baru
    Proses
    Selesai
    Ditolak
}

model User {
    id String @id @default(cuid())
    username String @unique
    password String
    role Role @default(Warga)
    nama String
    createdAt DateTime @default(now())
    laporan Laporan[]
    leaderboard Leaderboard?
}

model Laporan {
    id String @id @default(cuid())
    judul String
    deskripsi String
    kategori Kategori
    fotoBefore String?
    fotoAfter String?
    status Status @default(Baru)
    kredibel Boolean @default(false)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    userId String
    user User @relation(fields: [userId], references: [id])
}

model Leaderboard {
    id               String   @id @default(cuid())
    totalPoin        Int      @default(0)
    laporanKredibel  Int      @default(0)
    laporanDitolak   Int      @default(0)
    updatedAt        DateTime @updatedAt
    userId           String   @unique
    user             User     @relation(fields: [userId], references: [id])
}
